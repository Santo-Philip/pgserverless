# ─── Environment ───────────────────────────────────────────
APP_ENV=production
LOG_LEVEL=info

# ─── Database ──────────────────────────────────────────────
# Individual vars (used when DATABASE_URL is empty)
DB_HOST=postgres
DB_PORT=5432
DB_USER=api_admin
DB_PASSWORD=change_me_secure_password_123
DB_NAME=postgres_api
DB_SSLMODE=disable

# ─── Redis ─────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password
REDIS_DB=0

# ─── JSON Web Tokens ──────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=change_me_jwt_secret_at_least_32_chars_long

# ─── PostgREST ─────────────────────────────────────────────
POSTGREST_URL=http://postgrest:3000
POSTGREST_ADMIN_URL=http://postgrest:3001

# ─── Container ports (internal) ───────────────────────────
MGMT_PORT=8081
DASHBOARD_PORT=5173

# ─── Grafana ──────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=change_me_grafana_admin

# ─── Host-facing ports (auto-allocated by scripts/ports.sh) ─
API_PORT=2121
API_PORT_SSL=8443
GRAFANA_PORT=3000
