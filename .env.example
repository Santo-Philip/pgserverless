# ─── Environment ───────────────────────────────────────────
APP_ENV=production
APP_NAME=nexbic-platform
LOG_LEVEL=info

# ─── Database (use connection string or individual vars) ───
# DATABASE_URL takes precedence over individual DB_* vars
DATABASE_URL=postgres://api_admin:change_me_secure_password_123@postgres:5432/postgres_api?sslmode=disable

# Individual database settings (used only when DATABASE_URL is empty)
DB_HOST=postgres
DB_PORT=5432
DB_USER=api_admin
DB_PASSWORD=change_me_secure_password_123
DB_NAME=postgres_api
DB_SSLMODE=disable
DB_MAX_CONNS=25
DB_MIN_CONNS=5
DB_MAX_CONN_LIFETIME=30m
DB_MAX_CONN_IDLE_TIME=10m
DB_HEALTH_CHECK_PERIOD=1m

# ─── Redis (use connection string or individual vars) ──────
# REDIS_URL takes precedence over individual REDIS_* vars
REDIS_URL=redis://:change_me_redis_password@redis:6379/0

# Individual Redis settings
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password
REDIS_DB=0

# ─── Asynq (background job queue) ──────────────────────────
ASYNQ_CONCURRENCY=10

# ─── JSON Web Tokens ──────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=change_me_jwt_secret_at_least_32_chars_long
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
JWT_ISSUER=nexbic-platform
JWT_AUD=nexbic-platform

# ─── PostgREST ─────────────────────────────────────────────
POSTGREST_URL=http://postgrest:3000
POSTGREST_ADMIN_URL=http://postgrest:3001
POSTGREST_TIMEOUT=30s

# ─── Server (Go services: gateway, management-api) ─────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s
SERVER_SHUTDOWN_TIMEOUT=10s

# Management API runs on a separate port
MGMT_PORT=8081

# ─── CORS ──────────────────────────────────────────────────
# Comma-separated. Set to specific origins in production.
# Example: http://yourdomain.com,https://yourdomain.com
CORS_ORIGINS=*

# ─── Caddy / TLS ───────────────────────────────────────────
# Set to your domain for auto-TLS (Let's Encrypt)
# Leave empty for IP-based access (HTTP only)
DOMAIN=
# Email required for Let's Encrypt certificate issuance
ACME_EMAIL=

# ─── Dashboard (SvelteKit) ────────────────────────────────
# The public URL users access the dashboard at
DASHBOARD_ORIGIN=
DASHBOARD_PORT=5173
# Public API port for browser-side API calls (SvelteKit $env/dynamic/public)
PUBLIC_API_PORT=8080

# ─── Monitoring ────────────────────────────────────────────
MONITORING_ENABLED=true
METRIC_PATH=/metrics

# Grafana (default login: admin / ${GRAFANA_ADMIN_PASSWORD})
GRAFANA_ADMIN_PASSWORD=change_me_grafana_admin

# ─── Ports (auto-allocated by scripts/ports.sh) ────────────
# These are the host-facing ports. The services inside Docker
# use fixed internal ports defined above.
API_PORT=8080
API_PORT_SSL=8443
GRAFANA_PORT=3000
DASHBOARD_PORT=5173
