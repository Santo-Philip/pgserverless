# App
APP_NAME=nexbic-platform
APP_ENV=development
LOG_LEVEL=info

# Server
SERVER_PORT=8080
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s
CORS_ORIGINS=*

# PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_USER=api_admin
DB_PASSWORD=change_me_secure_password_123
DB_NAME=postgres_api
DB_SSLMODE=disable
DB_MAX_CONNS=20
DB_MIN_CONNS=2

# PgBouncer (uses same credentials)
PGBOUNCER_PORT=6432

# JWT
JWT_SECRET=change_me_jwt_secret_at_least_32_chars_long
JWT_AUD=nexbic-platform
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# PostgREST
POSTGREST_URL=http://postgrest:3000
POSTGREST_TIMEOUT=30s

# Asynq (uses Redis)
ASYNQ_HOST=redis
ASYNQ_PORT=6379
ASYNQ_PASSWORD=
ASYNQ_DB=1
ASYNQ_CONCURRENCY=10

# Api
API_PORT=8080

# Monitoring
MONITORING_ENABLED=true
METRIC_PATH=/metrics
GRAFANA_PORT=3000
